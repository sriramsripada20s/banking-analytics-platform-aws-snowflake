{
  "project_config": {
    "database": "FINTECH_PROD",
    "schema": "GOVERNANCE",
    "project_name": "banking-analytics-platform-aws-snowflake",
    "default_warehouse": "DBT_WH",
    "default_target": "dev"
  },
  "tasks": [
    {"name": "run_staging", "dbt_command": "run --select tag:staging", "depends_on": [], "schedule": "USING CRON 0 8 * * * UTC"},
    {"name": "test_staging", "dbt_command": "test --select tag:staging", "depends_on": ["run_staging"]},
    {"name": "run_intermediate", "dbt_command": "run --select tag:intermediate", "depends_on": ["test_staging"]},
    {"name": "test_intermediate", "dbt_command": "test --select tag:intermediate", "depends_on": ["run_intermediate"]},
    {"name": "run_marts", "dbt_command": "run --select tag:marts", "depends_on": ["test_intermediate"]},
    {"name": "test_marts", "dbt_command": "test --select tag:marts", "depends_on": ["run_marts"]}
  ]
}
